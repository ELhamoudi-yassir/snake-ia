class Food {
  PVector pos;//position defood

  //---------------------------------------------------------------------------------------------------------------------------------------------------------  
  //constructor
  Food() {
    

    pos = new PVector();
    // initialiser la position aleatoire
    pos.x = 220+floor(random(0, 77)) * 10;
    pos.y = 10+floor(random(0, 79)) * 10;
  }
  //---------------------------------------------------------------------------------------------------------------------------------------------------------  
  //afficher la fruit
  void show() {
    fill(255, 0, 0);
    rect(pos.x, pos.y, 10, 10);
  }
  //---------------------------------------------------------------------------------------------------------------------------------------------------------  
  //afficher clone de fruit
  Food clone() {
    Food clone = new Food();
    clone.pos = new PVector(pos.x, pos.y);

    
    return clone;
  }

}
